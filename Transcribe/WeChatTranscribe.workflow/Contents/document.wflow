				<key>ActionBundlePath</key>
				<string>/System/Library/Automator/Run Shell Script.action</string>
				<key>ActionName</key>
				<string>Run Shell Script</string>
				<key>ActionParameters</key>
				<dict>
					<key>COMMAND_STRING</key>
					<string>#!/bin/bash
export PATH="/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"
BASE="$HOME/Documents/WeChatTranscript"
LOG="/tmp/wct-quickaction.log"
for f in "$@"; do
  osascript -e 'display notification "开始转写,大约几分钟,请稍候…" with title "微信转写"'
  if "$BASE/transcribe.sh" "$f" &gt; "$LOG" 2&gt;&amp;1; then
    stem="$(basename "${f%.*}")"
    osascript -e "display notification \"完成:${stem}.txt\" with title \"微信转写\""
    open -R "$BASE/transcripts/${stem}.txt"
  else
    osascript -e 'display notification "转写失败,详见日志" with title "微信转写"'
    open "$LOG"
  fi
done</string>
